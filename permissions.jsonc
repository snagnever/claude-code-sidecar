// ============================================================================
// permissions.jsonc — Permission rules for the bash_filter.py Claude Code hook
// ============================================================================
//
// FORMAT: JSONC (JSON with Comments). Both // and /* */ comments are supported.
//
// STRUCTURE:
//   Top-level keys are tool types ("bash" for now; "mcp", "sites", etc. later).
//   Each tool type contains up to four lists, evaluated in this priority order:
//
//   1. blocklist  — DENY:  command is blocked, reason shown to Claude
//   2. alterlist  — ALTER: command is rewritten and auto-approved
//   3. asklist    — ASK:   user is prompted to confirm
//   4. allowlist  — ALLOW: command runs without prompting
//
//   If no list matches, the hook passes through to Claude Code's default
//   permission flow.
//
// RULE FIELDS (common to all lists):
//   "pattern"  (required)  Regex for detection.
//   "reason"   (required)  Human-readable explanation.
//   "match"    (optional)  "search" (default) = match anywhere in the command.
//                          "match" = must match from the start of the command.
//
// ALTERLIST EXTRA FIELDS (at least one rewrite field required):
//   "sub_pattern"      Regex for substitution (used with re.sub, count=1).
//   "sub_replacement"  Replacement string (supports \1 backreferences).
//   "prepend"          String prepended to the entire command.
//   "append"           String appended to the entire command.
//   Precedence: sub_pattern/sub_replacement > prepend > append.
//
// TIPS:
//   - Backslashes must be double-escaped in JSON: \b becomes \\b
//   - Use (?s:...) for dotall mode (. matches newlines) in multi-line commands
//   - Use (?i) for case-insensitive matching
//   - blocklist uses "search" by default (matches anywhere in the command)
//   - allowlist typically uses "match" (must start with the pattern)
//   - Rules are evaluated top-to-bottom within each list; first match wins
//   - A command matching blocklist is ALWAYS denied even if it also matches
//     alterlist, asklist, or allowlist
//
// INSTALL LOCATION: ~/.claude/hooks/permissions.jsonc
// ============================================================================
{
  "version": 1,

  "bash": {

    // -----------------------------------------------------------------------
    // BLOCKLIST — always denied, regardless of other lists
    // Uses re.search (match anywhere in command) by default.
    // -----------------------------------------------------------------------
    "blocklist": [
      // Destructive file operations
      {
        "pattern": "rm\\s+-[^\\s]*r[^\\s]*\\s+-[^\\s]*f|rm\\s+-[^\\s]*f[^\\s]*\\s+-[^\\s]*r|rm\\s+-rf|rm\\s+-fr",
        "reason": "Recursive force delete (rm -rf) is not allowed",
        "match": "search"
      },
      // Force push to remote
      {
        "pattern": "git\\s+push\\s+.*--force|git\\s+push\\s+.*-f\\b",
        "reason": "Force push to remote is not allowed",
        "match": "search"
      },
      // Curl/wget pipe to shell — remote code execution
      {
        "pattern": "curl\\b.*\\|\\s*(bash|sh|zsh|fish|python|python3|ruby|perl|node)",
        "reason": "Downloading and executing remote scripts is not allowed",
        "match": "search"
      },
      {
        "pattern": "wget\\b.*-O\\s*-.*\\|\\s*(bash|sh|zsh)",
        "reason": "Downloading and executing remote scripts is not allowed",
        "match": "search"
      },
      // Destructive SQL
      {
        "pattern": "(?i)\\bDROP\\s+(TABLE|DATABASE|SCHEMA)\\b",
        "reason": "Destructive SQL operations are not allowed",
        "match": "search"
      },
      {
        "pattern": "(?i)\\bTRUNCATE\\s+TABLE\\b",
        "reason": "TRUNCATE TABLE is not allowed",
        "match": "search"
      },
      {
        "pattern": "(?i)\\bDELETE\\s+FROM\\b(?!.*WHERE)",
        "reason": "DELETE without WHERE clause is not allowed",
        "match": "search"
      },
      // Write to production database without read-only flag
      {
        "pattern": "psql\\b(?!.*PGOPTIONS.*read_only).*-c\\s+['\"]?\\s*(INSERT|UPDATE|DELETE|DROP|TRUNCATE|ALTER)\\b",
        "reason": "Direct database write operations are not allowed",
        "match": "search"
      }
    ],

    // -----------------------------------------------------------------------
    // ALTERLIST — command is rewritten for safety and auto-approved
    // Uses re.search by default. Requires at least one rewrite field:
    //   sub_pattern + sub_replacement, or prepend, or append.
    // -----------------------------------------------------------------------
    "alterlist": [
      // Auto-add --dry-run to rsync (unless already present)
      {
        "pattern": "\\brsync\\b(?!.*--dry-run)",
        "sub_pattern": "\\brsync\\b",
        "sub_replacement": "rsync --dry-run",
        "reason": "Added --dry-run to rsync for safety",
        "match": "search"
      },
      // Auto-add --dry-run to git clean (unless -n or --dry-run already present)
      {
        "pattern": "\\bgit\\s+clean\\b(?!.*-n|.*--dry-run)",
        "sub_pattern": "\\bgit\\s+clean\\b",
        "sub_replacement": "git clean --dry-run",
        "reason": "Added --dry-run to git clean for safety",
        "match": "search"
      }
    ],

    // -----------------------------------------------------------------------
    // ASKLIST — user is prompted to confirm before execution
    // Uses re.search by default. The "reason" is shown in the permission dialog.
    // -----------------------------------------------------------------------
    "asklist": [
      // rm (non-recursive — rm -rf is caught by blocklist first)
      {
        "pattern": "\\brm\\s+",
        "reason": "rm command — confirm file deletion",
        "match": "search"
      },
      // find with side effects
      {
        "pattern": "\\bfind\\b.*(-exec|-execdir|-ok|-okdir|-delete)",
        "reason": "find with side effects — confirm execution",
        "match": "search"
      },
      // Git repo modifications (commit, stash, rebase, merge)
      {
        "pattern": "\\bgit\\s+(commit|stash|rebase|merge)\\b",
        "reason": "Git repository modification — confirm",
        "match": "search"
      },
      // File permission changes
      {
        "pattern": "\\b(chmod|chown)\\b",
        "reason": "Permission change — confirm",
        "match": "search"
      },
      // Package installations
      {
        "pattern": "\\b(pip|pip3)\\s+install\\b",
        "reason": "Python package installation — confirm",
        "match": "search"
      },
      {
        "pattern": "\\bnpm\\s+install\\b",
        "reason": "npm package installation — confirm",
        "match": "search"
      },
      {
        "pattern": "\\bbrew\\s+install\\b",
        "reason": "Homebrew package installation — confirm",
        "match": "search"
      },
      // Docker resource removal
      {
        "pattern": "\\bdocker\\s+(rm|rmi|system\\s+prune|volume\\s+rm)\\b",
        "reason": "Docker resource removal — confirm",
        "match": "search"
      }
    ],

    // -----------------------------------------------------------------------
    // ALLOWLIST — auto-approved without prompting
    // Uses re.match (from start of command) by default, so commands must
    // START with the pattern. Use (?s:...) for dotall mode on multi-line cmds.
    // -----------------------------------------------------------------------
    "allowlist": [
      // Shell navigation and inspection
      {
        "pattern": "(?s:(cd|pwd|which|echo|mkdir|find).*)\\Z",
        "reason": "Shell navigation and inspection",
        "match": "match"
      },
      {
        "pattern": "(?s:ls.*)\\Z",
        "reason": "List directory contents",
        "match": "match"
      },
      // Read-only git operations
      {
        "pattern": "(?s:git\\ (diff|log|status|branch|checkout|fetch|show).*)\\Z",
        "reason": "Read-only git operations",
        "match": "match"
      },
      // Read-only PostgreSQL (with PGOPTIONS read-only flag)
      {
        "pattern": "(?s:PGOPTIONS=\"\\-c\\ default_transaction_read_only=on\"\\ psql\\ \"postgresql://postgres:postgres@localhost:5432/geo_brand_monitor(_test)?\".*)\\Z",
        "reason": "Read-only PostgreSQL",
        "match": "match"
      },
      // Backend tooling — poetry commands
      {
        "pattern": "(?s:poetry\\ run\\ poe.*)\\Z",
        "reason": "Backend tooling",
        "match": "match"
      },
      {
        "pattern": "(?s:poetry\\ run\\ ruff.*)\\Z",
        "reason": "Backend tooling",
        "match": "match"
      },
      {
        "pattern": "(?s:poetry\\ run\\ mypy.*)\\Z",
        "reason": "Backend tooling",
        "match": "match"
      },
      {
        "pattern": "(?s:poetry\\ run\\ pytest.*)\\Z",
        "reason": "Backend tooling",
        "match": "match"
      },
      {
        "pattern": "(?s:poetry\\ run\\ alembic\\ (head|heads|current|history).*)\\Z",
        "reason": "Backend tooling",
        "match": "match"
      },
      // Frontend — npm test and lint commands
      {
        "pattern": "(?s:npm\\ (test|run\\ (lint|lint:strict|validate|format)).*)\\Z",
        "reason": "Frontend test and lint",
        "match": "match"
      },
      {
        "pattern": "(?s:npx\\ (next\\ lint|eslint|prettier).*)\\Z",
        "reason": "Frontend lint/format via npx",
        "match": "match"
      },
      // Text and process utilities (read-only or safe)
      {
        "pattern": "(?s:(sort|uniq|wc|head|tail|grep|sed|awk|tr|touch|pgrep).*)\\Z",
        "reason": "Text and process inspection utilities",
        "match": "match"
      },
      {
        "pattern": "(?s:cat(?>.*?\\|)(?>.*?grep).*)\\Z",
        "reason": "cat with grep (read-only pipeline)",
        "match": "match"
      },
      // Project spec scripts
      {
        "pattern": "(?s:\\.specify/scripts/bash/.*)\\Z",
        "reason": "Project spec scripts under .specify/scripts/bash",
        "match": "match"
      }
    ]
  }
}
